{
  "crons": [
    {
      "path": "/api/funnel/run",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/replies/process",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/onboarding-reminders/process",
      "schedule": "*/5 * * * *"
    }
  ],
  "functions": {
    "src/app/api/videos/[id]/route.ts": {
      "maxDuration": 300,
      "includeFiles": "node_modules/@sparticuz/chromium/bin/**"
    }
  }
}
