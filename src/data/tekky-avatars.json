{
  "name": "Tekky Avatar System",
  "version": "2.0.0",
  "client": "Zenith Sports \u2014 TEKKY\u00ae",
  "description": "Pixar-style 3D character avatar cards for the Tekky in-app skill tier system. Two character sets (male + female), 5 skill tiers \u00d7 3 age groups each = 30 total cards.",
  "total_cards": 30,
  "image_format": {
    "extension": ".png",
    "mime_type": "image/jpeg",
    "aspect_ratio": "3:4 portrait",
    "resolution": "2K",
    "color_space": "sRGB"
  },
  "design_system": {
    "background_gradient": [
      "#0a1628",
      "#1e3a5f"
    ],
    "characters": {
      "male": {
        "description": "Tan caramel-bronze 'everyman' with bright blonde hair. Same character ages and develops across tiers.",
        "hair": "Short blonde tousled (kid/teen). Adult tiers add light scruff (TRAVEL/CLUB), short beard (ECNL), full beard (ELITE).",
        "facial_hair_rules": {
          "5-15": "None.",
          "13-25": "None \u2014 clean-shaven across ALL 5 tiers.",
          "25-35": "Light scruff at TRAVEL/CLUB; short beard at ECNL; full beard at ELITE."
        }
      },
      "female": {
        "description": "Tan caramel-bronze 'everyman' with bright blonde hair, light freckles. Same character ages and develops across tiers.",
        "hair": "Athletic ponytail with loose tendrils framing the face across all ages and tiers.",
        "facial_hair_rules": {
          "5-15": "None.",
          "13-25": "None.",
          "25-35": "None \u2014 female across all ages."
        }
      }
    },
    "ball": {
      "name": "TEKKY training ball",
      "description": "White carbon-fiber-textured base panels with iridescent ribbon graphics in teal/cyan, royal blue, and purple/violet (with black outline edges). Bold black 'TEKKY' wordmark on front-center white panel. Circular Zenith Sports 'Z' medallion at the top.",
      "source": "https://zenithsports.org/products/the-tekky-advanced-youth-training-ball"
    },
    "pose": "Both bare hands wrapped around the Tekky ball, held at chest level. NO gloves anywhere across either set.",
    "stars_rule": "Equal split: half upper-left, half upper-right. Color matches tier accent (sky-blue for REC, red for TRAVEL, purple for CLUB, gold for ECNL/MLS NEXT and ELITE).",
    "label_rule": "Tier name (large bold sans-serif) at bottom of card. Age range below in smaller text."
  },
  "tiers": [
    {
      "id": 1,
      "name": "REC",
      "slug": "rec",
      "stars": 2,
      "jersey_number": 7,
      "jersey_color": "Sky Blue",
      "jersey_color_hex": "#38BDF8",
      "description": "Recreational level \u2014 beginner. Lean build, basic kit only."
    },
    {
      "id": 2,
      "name": "TRAVEL",
      "slug": "travel",
      "stars": 4,
      "jersey_number": 10,
      "jersey_color": "Crimson Red",
      "jersey_color_hex": "#DC2626",
      "description": "Travel team \u2014 competitive youth soccer beyond rec."
    },
    {
      "id": 3,
      "name": "CLUB",
      "slug": "club",
      "stars": 6,
      "jersey_number": 9,
      "jersey_color": "Royal Purple",
      "jersey_color_hex": "#7C3AED",
      "description": "Club soccer \u2014 serious competitive level. Captain of the team."
    },
    {
      "id": 4,
