      "label": "kid"
    },
    {
      "slug": "13-25",
      "range": "13\u201325",
      "label": "teen / young adult"
    },
    {
      "slug": "25-35",
      "range": "25\u201335",
      "label": "adult"
    }
  ],
  "genders": [
    "male",
    "female"
  ],
  "lookup": {
    "filename_pattern": "cards/{gender}/{NN}_{tier_slug}_age_{age_slug}.png",
    "tier_slugs": [
      "rec",
      "travel",
      "club",
      "ecnl_mls_next",
      "elite"
    ],
    "age_slugs": [
      "5-15",
      "13-25",
      "25-35"
    ],
    "age_brackets": {
      "<13": "5-15",
      "13-24": "13-25",
      ">=25": "25-35"
    }
  },
  "changelog": [
