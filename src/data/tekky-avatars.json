  "description": "Pixar-style 3D character avatar cards for the Tekky in-app skill tier system.",
  "total_cards": 15,
  "image_format": {
    "extension": ".png",
    "mime_type": "image/jpeg",
    "aspect_ratio": "3:4 portrait",
    "resolution": "2K",
    "color_space": "sRGB"
  },
  "design_system": {
    "background_gradient": [
      "#0a1628",
      "#1e3a5f"
    ],
    "character": {
      "look": "Tan caramel-bronze 'everyman' with bright blonde hair. Same character ages and develops across tiers.",
      "facial_hair_rules": {
        "5-15": "None \u2014 kid faces are smooth.",
        "13-25": "None \u2014 clean-shaven across ALL 5 tiers.",
        "25-35": "Light scruff at TRAVEL & CLUB; short groomed beard at ECNL/MLS NEXT; full mature beard at ELITE."
      }
    },
    "ball": {
      "name": "TEKKY training ball",
      "description": "White carbon-fiber-textured base panels with iridescent ribbon graphics in teal/cyan, royal blue, and purple/violet (with black outline edges). Bold black 'TEKKY' wordmark on front-center white panel. Circular Zenith Sports 'Z' medallion at top.",
      "source": "https://zenithsports.org/products/the-tekky-advanced-youth-training-ball"
    },
    "pose": "Both hands wrapped around the Tekky ball, held at chest level (slightly elevated for ELITE). Bare hands across all tiers \u2014 no gloves anywhere.",
    "stars_rule": "Equal split: half on upper-left of card, half on upper-right. Color-matched to tier accent (sky-blue for REC, red for TRAVEL, purple for CLUB, gold for ECNL/MLS NEXT and ELITE).",
    "label_rule": "Tier name (large bold sans-serif) at bottom of card. Age range below in smaller text."
  },
