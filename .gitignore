# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# pipeline data — runtime caches, NOT curated content
/data/emails/
/data/scraped/
/data/sms/
/data/prospects.json
/data/prospects_audit.json
/data/regen_em.json
/data/*.json
# (the voice-corpus subfolder under /data/ IS curated content and ships in
# git so loadVoiceCorpus() can bundle it on Vercel deploys per Rule 76)

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel

# Loose test images dropped at repo root by ad-hoc tools — never commit these
/*.jpg
/*.jpeg
/*.png

# Video render working folder (locally cached clips, captions, previews)
edit-cache/

# B-roll library — manifest + recording guide are tracked,
# but actual mp4 clips stay local until promoted via 'git add -f'
content-assets/broll/**/*.mp4
content-assets/broll/**/*.mov
content-assets/broll/**/*.MOV

.env*.local

